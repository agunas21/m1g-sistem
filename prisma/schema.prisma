// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// ÜYELER
// ─────────────────────────────────────────────
model Member {
  id            String    @id @default(uuid())
  kimlikToken   String    @unique @default(cuid())
  fullName      String
  tcNo          String?   // AES-256-GCM şifreli
  gender        String?
  phone         String?
  email         String    @unique
  password      String    // bcrypt hash
  profession    String?
  education     String?
  memberType    String    @default("Üye")
  honorary      String    @default("Hayır")
  status        String    @default("Aktif")
  isAdmin       Boolean   @default(false)
  isSuperAdmin  Boolean   @default(false)
  role          String?
  joinDate      DateTime  @default(now())
  birthDate     String?
  bloodType     String?
  emergencyContact String?
  address       String?
  avatar        String?
  lastLogin         DateTime?
  bannedAt          DateTime?
  bannedBy          String?
  banReason         String?
  totpSecret        String?
  totpPendingSecret String?
  totpEnabled       Boolean   @default(false)
  totpBackupCodes   Json      @default("[]")
  resetToken        String?
  resetTokenExpiry  DateTime?
  passwordChangedAt DateTime?
  ftrRecords        Json      @default("[]")
  certificates      Json      @default("[]")
  inventory         Json      @default("[]")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  auditLogs     AuditLog[]
  teamMembers   TeamMember[]
  assignedItems InventoryItem[]

  @@index([email])
  @@index([status])
}

// ─────────────────────────────────────────────
// ENVANTERLİK
// ─────────────────────────────────────────────
model InventoryItem {
  id              String    @id
  name            String
  category        String
  status          String    @default("Depoda")
  isContainer     Boolean   @default(false)
  containerItems  String[]  @default([])
  assignedToId    String?
  assignedTo      Member?   @relation(fields: [assignedToId], references: [id], onDelete: SetNull)
  condition       String    @default("İyi")
  type            String    @default("Demirbaş")
  expirationDate  String?
  maintenanceDate String?
  lastMaintenance String?
  damagePhotos    String[]  @default([])
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([status])
  @@index([assignedToId])
}

// ─────────────────────────────────────────────
// OPERASYONLAR
// ─────────────────────────────────────────────
model Operation {
  id                  String    @id @default(cuid())
  name                String
  type                String    // Deprem | Yangın | Doğada Arama | Eğitim | Kamp
  status              String    @default("Aktif")
  startTime           DateTime  @default(now())
  endTime             DateTime?
  location            String?
  temperature         String?
  radioFrequency      String?
  isEvacuationActive  Boolean   @default(false)
  supplies            Json      @default("{}")
  baseCampMembers     String[]  @default([])
  baseCampEquipment   String[]  @default([])
  logs                Json      @default("[]")
  postMortemReport    Json      @default("{\"completed\":false,\"notes\":\"\",\"memberNotes\":{}}")
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  teams       Team[]
  auditLogs   AuditLog[]
}

// ─────────────────────────────────────────────
// TİMLER
// ─────────────────────────────────────────────
model Team {
  id          String    @id @default(cuid())
  name        String
  status      String    @default("Hazırda")
  operationId String
  operation   Operation @relation(fields: [operationId], references: [id], onDelete: Cascade)
  equipment   String[]  @default([])
  createdAt   DateTime  @default(now())

  members     TeamMember[]
  deployments Deployment[]

  @@index([operationId])
}

model TeamMember {
  id       String @id @default(cuid())
  teamId   String
  memberId String
  role     String @default("Üye") // Lider | Üye

  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([teamId, memberId])
  @@index([teamId])
  @@index([memberId])
}

model Deployment {
  id             String    @id @default(cuid())
  teamId         String
  team           Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  deployTime     DateTime  @default(now())
  returnTime     DateTime?
  targetLocation String?
  pulse          String?   // Yeşil | Sarı | Kırmızı

  @@index([teamId])
}

// ─────────────────────────────────────────────
// BAŞVURULAR & ONAYLAR
// ─────────────────────────────────────────────
model Application {
  id          String   @id @default(cuid())
  fullName    String
  email       String
  phone       String?
  message     String?
  status      String   @default("Beklemede") // Beklemede | Onaylandı | Reddedildi
  createdAt   DateTime @default(now())
}

// ─────────────────────────────────────────────
// BELGELER
// ─────────────────────────────────────────────
model Document {
  id          String   @id @default(cuid())
  title       String
  category    String?
  url         String
  uploadedBy  String?
  createdAt   DateTime @default(now())
}

// ─────────────────────────────────────────────
// AUDIT LOG — SESSİZ KAYIT DEFTERİ
// ─────────────────────────────────────────────
model AuditLog {
  id          String    @id @default(cuid())
  actorId     String?
  actorName   String?
  actor       Member?   @relation(fields: [actorId], references: [id], onDelete: SetNull)
  action      String    // inventory.assign | operation.close | member.create | team.deploy ...
  detail      String    // İnsan okunabilir: "Ali, Jeneratörü Alfa Timine zimmetledi"
  entityType  String?   // Member | Inventory | Operation | Team
  entityId    String?
  operationId String?
  operation   Operation? @relation(fields: [operationId], references: [id], onDelete: SetNull)
  ipAddress   String?
  userAgent   String?
  severity    String    @default("INFO") // INFO | WARN | ERROR | CRITICAL
  createdAt   DateTime  @default(now())

  @@index([actorId])
  @@index([action])
  @@index([createdAt])
  @@index([operationId])
  @@index([entityType, entityId])
}

// ─────────────────────────────────────────────
// SİTE AYARLARI
// ─────────────────────────────────────────────
model SiteConfig {
  key       String @id
  value     Json
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────
// VİDEO KÜTÜPHANESİ
// ─────────────────────────────────────────────
model Video {
  id          String   @id @default(cuid())
  title       String
  description String?
  url         String
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
